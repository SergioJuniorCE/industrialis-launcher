{
  "name": "industrialis-launcher",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "@orpc/client": "^1.13.14"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:desktop": "turbo -F desktop dev:hmr",
    "build:desktop": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @industrialis-launcher/db db:push",
    "db:studio": "turbo -F @industrialis-launcher/db db:studio",
    "db:generate": "turbo -F @industrialis-launcher/db db:generate",
    "db:migrate": "turbo -F @industrialis-launcher/db db:migrate",
    "db:local": "turbo -F @industrialis-launcher/db db:local",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@industrialis-launcher/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@industrialis-launcher/config": "workspace:*",
    "@types/bun": "^1.3.4",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
